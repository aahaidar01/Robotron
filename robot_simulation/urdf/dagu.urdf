<?xml version="1.0" ?>
<robot name="turtlebot3_waffle" xmlns:xacro="http://ros.org/wiki/xacro">
  <!-- <xacro:include filename="$(find turtlebot3_description)/urdf/common_properties.urdf"/>

  <xacro:property name="r200_cam_rgb_px" value="0.005"/>
  <xacro:property name="r200_cam_rgb_py" value="0.018"/>
  <xacro:property name="r200_cam_rgb_pz" value="0.013"/>
  <xacro:property name="r200_cam_depth_offset" value="0.01"/> -->
  <!-- Init colour -->
  <material name="black">
      <color rgba="0.0 0.0 0.0 1.0"/>
  </material>

  <material name="dark">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>

  <material name="light_black">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>

  <material name="blue">
    <color rgba="0.0 0.0 0.8 1.0"/>
  </material>

  <material name="green">
    <color rgba="0.0 0.8 0.0 1.0"/>
  </material>

  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="orange">
    <color rgba="1.0 0.4235 0.0392 1.0"/>
  </material>

  <material name="brown">
    <color rgba="0.8706 0.8118 0.7647 1.0"/>
  </material>

  <material name="red">
    <color rgba="0.8 0.0 0.0 1.0"/>
  </material>

  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link" />
    <origin xyz="0 0 0.095" rpy="0 0 0"/> <!-- 6cm ground clearance + 3.5cm to mid of body -->
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.035" rpy="0 0 0"/> <!-- -0.064 -->
      <geometry>
        <mesh filename="package://robot_simulation/meshes/dagu_chassis_moved_lidar.stl" scale="0.1 0.1 0.1"/>
        <!-- <box size="0.230 0.120 0.070"/> -->
      </geometry>
      <material name="light_black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.230 0.120 0.070"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- Need to update weight based on DAGU platform. Doc mentions 1.9kg but may weigh more due to sensors + battery etc-->
      <mass value="3.0"/>
        <inertia ixx="0.00487" ixy="0.0" ixz="0.0"
                 iyy="0.0145" iyz="0.0"
                 izz="0.0168" />
    </inertial>
  </link>

  <!-- Front Left Wheel -->
  <joint name="wheel_front_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_left_link"/>
    <origin xyz="0.075 0.12 -0.035" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_front_left_link">
    <visual>
      <origin xyz="0 -0.01 0" rpy="1.57 0 0"/>
      <geometry>
        <mesh filename="package://robot_simulation/meshes/dagu_tire_left.stl" scale="0.1 0.1 0.1"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.060" radius="0.060"/> <!-- length: thickness of wheel -->
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="0.15" />
      <inertia ixx="0.00018" ixy="0.0" ixz="0.0"
               iyy="0.00018" iyz="0.0"
               izz="0.00027" />
      </inertial>
  </link>

  <!-- Front Right Wheel -->
  <joint name="wheel_front_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_right_link"/>
    <origin xyz="0.075 -0.120 -0.035" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_front_right_link">
    <visual>
      <origin xyz="0 -0.01 0" rpy="1.57 0 0"/>
      <geometry>
        <mesh filename="package://robot_simulation/meshes/dagu_tire_right.stl" scale="0.1 0.1 0.1"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.060" radius="0.060"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="0.15" />
      <inertia ixx="0.00018" ixy="0.0" ixz="0.0"
               iyy="0.00018" iyz="0.0"
               izz="0.00027" />
      </inertial>
  </link>

  <!-- Rear Left Wheel -->
  <joint name="wheel_rear_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rear_left_link"/>
    <origin xyz="-0.075 0.12 -0.035" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_rear_left_link">
    <visual>
      <origin xyz="0 -0.01 0" rpy="1.57 0 0"/>
      <geometry>
        <mesh filename="package://robot_simulation/meshes/dagu_tire_left.stl" scale="0.1 0.1 0.1"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.060" radius="0.060"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="0.15" />
      <inertia ixx="0.00018" ixy="0.0" ixz="0.0"
               iyy="0.00018" iyz="0.0"
               izz="0.00027" />
      </inertial>
  </link>

  <!-- Rear Right Wheel -->
  <joint name="wheel_rear_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rear_right_link"/>
    <origin xyz="-0.075 -0.120 -0.035" rpy="-1.57 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_rear_right_link">
    <visual>
      <origin xyz="0 -0.01 0" rpy="1.57 0 0"/>
      <geometry>
        <mesh filename="package://robot_simulation/meshes/dagu_tire_right.stl" scale="0.1 0.1 0.1"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.060" radius="0.060"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="0.15" />
      <inertia ixx="0.00018" ixy="0.0" ixz="0.0"
               iyy="0.00018" iyz="0.0"
               izz="0.00027" />
      </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0.0 0 0.068" rpy="0 0 0"/>
  </joint>

  <link name="imu_link"/>

  <joint name="scan_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_scan"/>
    <origin xyz="0.040 0 0.107" rpy="0 0 0"/>
  </joint>

  <link name="base_scan">
    <visual>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <!-- <mesh filename="package://robot_simulation/meshes/rplidar_a1m8.stl" scale="0.0001 0.0001 0.0001"/> -->
        <mesh filename="package://turtlebot3_description/meshes/sensors/lds.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="dark"/>
    </visual>

    <collision>
      <origin xyz="0.0 0 0.0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.060" radius="0.035"/> <!-- Length: Height of LiDAR = 60mm -->
      </geometry>
    </collision>

    <inertial>
      <mass value="0.170" />
      <origin xyz="0 0 0.03" />
      <inertia ixx="0.000103" ixy="0.0" ixz="0.0"
               iyy="0.000103" iyz="0.0"
               izz="0.000104" />
    </inertial>
  </link>

  <!-- Setting up robot simulation params for Gazebo -->

  <gazebo reference="wheel_front_left_link">
    <mu1>0.5</mu1> 
    <mu2>0.05</mu2>

    <fdir1>1 0 0 </fdir1> <!-- Friction direction for anisotropic friction -->
    <minDepth>0.001</minDepth> <!-- Minimum depth for contact -->
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/FlatBlack</material>
  </gazebo>

  <gazebo reference="wheel_front_right_link">
    <mu1>0.5</mu1> 
    <mu2>0.05</mu2>

    <fdir1>1 0 0 </fdir1> <!-- Friction direction for anisotropic friction -->
    <minDepth>0.001</minDepth> <!-- Minimum depth for contact -->
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/FlatBlack</material>
  </gazebo>

  <gazebo reference="wheel_rear_left_link">
    <mu1>0.5</mu1> 
    <mu2>0.05</mu2>

    <fdir1>1 0 0 </fdir1> <!-- Friction direction for anisotropic friction -->
    <minDepth>0.001</minDepth> <!-- Minimum depth for contact -->
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/FlatBlack</material>
  </gazebo>

  <gazebo reference="wheel_rear_right_link">
    <mu1>0.5</mu1> 
    <mu2>0.05</mu2>

    <fdir1>1 0 0 </fdir1> <!-- Friction direction for anisotropic friction -->
    <minDepth>0.001</minDepth> <!-- Minimum depth for contact -->
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/FlatBlack</material>
  </gazebo>

<gazebo reference="imu_link">
    <sensor type="imu" name="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate> 
      <imu>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.0017</stddev> </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.0017</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.0017</stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.017</stddev> </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.017</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.017</stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
      <plugin name="turtlebot3_imu" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <namespace></namespace>
          <remapping>~/out:=imu</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="base_scan">
    <sensor type="ray" name="lds_lfcd_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize> 
      <update_rate>5.5</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>6.28319</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.150</min>
          <max>12.0</max> <resolution>0.001</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev> </noise>
      </ray>
      <plugin name="turtlebot3_laserscan" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <namespace></namespace>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>base_scan</frame_name>
      </plugin>
    </sensor>
  </gazebo>

<!-- TODO: Check our DAGU real wheel specs and dim. This is CRITICAL to ensure accurate wheel encoder calcs -->
  <gazebo>
    <plugin name="turtlebot3_diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace></namespace>
      </ros>
      <update_rate>30</update_rate>

      <num_wheel_pairs>2</num_wheel_pairs>
      
      <left_joint>wheel_front_left_joint</left_joint>
      <right_joint>wheel_front_right_joint</right_joint>

      <left_joint>wheel_rear_left_joint</left_joint>
      <right_joint>wheel_rear_right_joint</right_joint>
      
      <wheel_separation>0.240</wheel_separation>
      <wheel_diameter>0.120</wheel_diameter>
      
      <wheel_separation>0.240</wheel_separation>
      <wheel_diameter>0.120</wheel_diameter>

      <max_wheel_torque>0.67</max_wheel_torque> 
      <max_wheel_acceleration>1.0</max_wheel_acceleration>

      <command_topic>cmd_vel</command_topic>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_topic>odom</odometry_topic>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

</robot>
